{
  "name": "body-measurement-and-clothing-visualization-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "node scripts/patch-polyfill.js",
    "server:install": "cd server/node && npm install",
    "server:dev": "cd server/node && npm run dev",
    "server:build": "cd server/node && npm run build",
    "server:db:push": "cd server/node && npx prisma db push",
    "server:db:studio": "cd server/node && npx prisma studio",
    "ai:install": "cd server/python && pip install -r requirements.txt",
    "ai:dev": "cd server/python && uvicorn app.server:app --reload --port 8000",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.18.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-three": "^8.0.0",
    "firebase": "^12.15.0",
    "react": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "^13.15.0",
    "three": "^0.166.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/three": "^0.166.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
