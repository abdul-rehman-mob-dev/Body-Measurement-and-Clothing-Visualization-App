# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bodyfitai

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin
FIREBASE_PROJECT_ID=reactnative-firebase-training
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@reactnative-firebase-training.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=bodyfitai-photos

# Python AI Service
AI_SERVICE_URL=http://localhost:8000
